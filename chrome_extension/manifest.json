{
  "manifest_version": 3,
  "name": "PhishGuard Monitor",
  "version": "1.0",
  "description": "PhishGuard URL Checker",

  "permissions": [
    "tabs",
    "webNavigation",
    "notifications"
  ],

  "host_permissions": [
    "http://127.0.0.1:5000/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "icons": {
    "128": "icon.png"
  }
}